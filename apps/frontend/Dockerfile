# ============================================\n# MIXMLAAL 前端服务 Dockerfile\n# 版本: v1.0.0.0\n# 说明: 基于 Nginx 部署前端静态文件\n# ============================================\n\n# 构建阶段\nFROM node:18-alpine AS builder\n\nWORKDIR /app\n\n# 复制依赖文件\nCOPY package*.json ./\n\n# 安装依赖\nRUN npm ci\n\n# 复制源代码\nCOPY . .\n\n# 构建前端\nRUN npm run build\n\n# 生产阶段\nFROM nginx:1.25-alpine\n\n# 复制构建产物\nCOPY --from=builder /app/dist /usr/share/nginx/html\n\n# 复制 Nginx 配置\nCOPY nginx.conf /etc/nginx/conf.d/default.conf\n\n# 暴露端口\nEXPOSE 80\n\n# 健康检查\nHEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \\n    CMD curl -f http://localhost || exit 1\n\n# 启动 Nginx\nCMD ["nginx", "-g", "daemon off;"]