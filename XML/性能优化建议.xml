      <heading level="4">3.2.2 响应数据优化</heading>
      <paragraph>// DTO 转换</paragraph>
      <paragraph>class OrderDTO {</paragraph>
      <paragraph>@Select() // 只查询需要的字段</paragraph>
      <paragraph>id: string;</paragraph>
      <paragraph>@Select()</paragraph>
      <paragraph>orderNo: string;</paragraph>
      <paragraph>@Select()</paragraph>
      <paragraph>status: string;</paragraph>
      <paragraph>// 排除敏感字段</paragraph>
      <paragraph>@Exclude()</paragraph>
      <paragraph>internalNotes: string;</paragraph>
      <paragraph>}</paragraph>
      <paragraph>// 批量数据处理</paragraph>
      <paragraph>export const batchProcess = async &lt;T&gt;(</paragraph>
      <paragraph>items: T[],</paragraph>
      <paragraph>processor: (item: T) =&gt; Promise&lt;Result&gt;,</paragraph>
      <paragraph>batchSize = 100</paragraph>
      <paragraph>): Promise&lt;Result[]&gt; =&gt; {</paragraph>
      <paragraph>const results: Result[] = [];</paragraph>
      <paragraph>for (let i = 0; i &lt; items.length; i += batchSize) {</paragraph>
      <paragraph>const batch = items.slice(i, i + batchSize);</paragraph>
      <paragraph>const batchResults = await Promise.all(batch.map(processor));</paragraph>
      <paragraph>results.push(...batchResults);</paragraph>
      <paragraph>}</paragraph>
      <paragraph>return results;</paragraph>
      <paragraph>
        };
