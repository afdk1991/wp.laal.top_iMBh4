    <paragraph>NAMESPACE=$1</paragraph>
    <paragraph>DEPLOYMENT=$2</paragraph>
    <paragraph>PREVIOUS_REVISION=${3:-1}</paragraph>
    <paragraph>echo "Starting rollback..."</paragraph>
    <paragraph>echo "Namespace: $NAMESPACE"</paragraph>
    <paragraph>echo "Deployment: $DEPLOYMENT"</paragraph>
    <paragraph>echo "Revision: $PREVIOUS_REVISION"</paragraph>
