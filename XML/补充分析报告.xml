    <paragraph>kubectl rollout history deployment/$DEPLOYMENT -n $NAMESPACE</paragraph>
  </section>
  <section>
    <heading level="1">执行回滚</heading>
    <paragraph>kubectl rollout undo deployment/$DEPLOYMENT \</paragraph>
    <paragraph>--to-revision=$PREVIOUS_REVISION \</paragraph>
    <paragraph>-n $NAMESPACE</paragraph>
  </section>
  <section>
    <heading level="1">等待回滚完成</heading>
    <paragraph>kubectl rollout status deployment/$DEPLOYMENT -n $NAMESPACE --timeout=300s</paragraph>
  </section>
