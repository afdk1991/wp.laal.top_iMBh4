    <heading level="1">验证转换合法性</heading>
    <paragraph>if target_status not in statusTransitions.get(order.status, []):</paragraph>
    <paragraph>raise InvalidStatusTransition(</paragraph>
    <paragraph>order_id=order_id,</paragraph>
    <paragraph>current=order.status,</paragraph>
    <paragraph>target=target_status</paragraph>
    <paragraph>)</paragraph>
  </section>
  <section>
    <heading level="1">执行转换</heading>
    <paragraph>old_status = order.status</paragraph>
    <paragraph>order.status = target_status</paragraph>
  </section>
  <section>
    <heading level="1">持久化</heading>
    <paragraph>await self.order_repo.save(order)</paragraph>
  </section>
  <section>
