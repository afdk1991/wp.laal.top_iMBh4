    <paragraph>await self.event_publisher.publish(OrderStatusChanged(</paragraph>
    <paragraph>order_id=order_id,</paragraph>
    <paragraph>old_status=old_status,</paragraph>
    <paragraph>new_status=target_status,</paragraph>
    <paragraph>context=context,</paragraph>
    <paragraph>timestamp=datetime.now()</paragraph>
    <paragraph>))</paragraph>
    <paragraph>
      return order
