<view class="order-list">
  <view class="order-item" wx:for="{{list}}" wx:key="id" bindtap="onItemClick" data-index="{{index}}">
    <view class="order-header">
      <text class="order-id">订单号: {{item.orderId}}</text>
      <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
    </view>
    <view class="order-content">
      <view class="order-info">
        <view class="info-row">
          <text class="info-label">出发地</text>
          <text class="info-value">{{item.fromAddress}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">目的地</text>
          <text class="info-value">{{item.toAddress}}</text>
        </view>
        <view class="info-row" wx:if="{{item.driverName}}">
          <text class="info-label">司机</text>
          <text class="info-value">{{item.driverName}} {{item.driverPhone}}</text>
        </view>
      </view>
      <view class="order-price">
        <text class="price-label">金额</text>
        <text class="price-value">¥{{item.price}}</text>
      </view>
    </view>
    <view class="order-footer">
      <text class="order-time">{{item.createTime}}</text>
      <view class="order-actions">
        <button class="action-btn" wx:if="{{item.status === 'pending'}}" catchtap="onCancel" data-id="{{item.id}}">取消订单</button>
        <button class="action-btn primary" wx:if="{{item.status === 'completed'}}" catchtap="onRate" data-id="{{item.id}}">评价</button>
        <button class="action-btn primary" wx:if="{{item.status === 'unpaid'}}" catchtap="onPay" data-id="{{item.id}}">去支付</button>
      </view>
    </view>
  </view>
</view>

<view class="empty-list" wx:if="{{!list.length}}">
  <text class="empty-text">暂无订单</text>
</view>
