.navbar-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
}

.navbar-status {
  width: 100%;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 30rpx;
}

.navbar-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.navbar-back-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
}

.navbar-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  color: #fff;
  font-weight: 500;
}

.navbar-right {
  width: 60rpx;
}

.navbar-placeholder {
  width: 100%;
}
