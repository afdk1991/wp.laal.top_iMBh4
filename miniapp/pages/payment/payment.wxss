.payment-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.order-section, .method-section, .tips-section {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
}

.order-id {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.order-amount {
  text-align: center;
}

.amount-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.amount-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.price-symbol {
  font-size: 32rpx;
  color: #f5222d;
}

.price-num {
  font-size: 56rpx;
  color: #f5222d;
  font-weight: 600;
}

.method-list {
  border-radius: 16rpx;
  overflow: hidden;
}

.method-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.method-item:last-child {
  border-bottom: none;
}

.method-item.active {
  background: #e6f7ff;
}

.method-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.method-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.method-check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.method-item.active .method-check {
  background: #1890ff;
  border-color: #1890ff;
}

.method-check text {
  font-size: 24rpx;
  color: #fff;
}

.tips-section {
  padding: 20rpx 30rpx;
}

.tips-text {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 2;
}

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.pay-btn {
  width: 100%;
  height: 88rpx;
  background: #1890ff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}
