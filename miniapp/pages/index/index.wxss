.index-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 40rpx 30rpx 60rpx;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo-section {
  display: flex;
  align-items: center;
}

.logo {
  width: 60rpx;
  height: 60rpx;
  margin-right: 16rpx;
}

.app-name {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.login-btn {
  padding: 10rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #fff;
}

.banner-section {
  margin: -40rpx 30rpx 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.banner-swiper {
  height: 300rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.service-section {
  background: #fff;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.service-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
  margin-bottom: 20rpx;
}

.service-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.service-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
  text-align: center;
}

.service-desc {
  font-size: 20rpx;
  color: #999;
  text-align: center;
  line-height: 1.3;
}

.quick-ride-section, .hot-section {
  background: #fff;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.section-more {
  font-size: 26rpx;
  color: #1890ff;
}

.quick-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.action-card {
  flex: 1;
  min-width: calc(25% - 15rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 25rpx 15rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-radius: 16rpx;
  margin: 0 7.5rpx 15rpx;
  transition: all 0.3s ease;
}

.action-card:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
}

.action-card:first-child {
  margin-left: 0;
}

.action-card:last-child {
  margin-right: 0;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.action-price {
  font-size: 24rpx;
  color: #1890ff;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-card {
  width: calc(50% - 10rpx);
  background: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 200rpx;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #f5222d;
}

.price-value {
  font-size: 28rpx;
  color: #f5222d;
  font-weight: 600;
}

.footer {
  text-align: center;
  padding: 40rpx 30rpx 60rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}
