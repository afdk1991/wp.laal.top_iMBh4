.detail-container {
  padding-bottom: 120rpx;
}

.image-section {
  position: relative;
}

.image-swiper {
  width: 100%;
  height: 750rpx;
}

.product-image {
  width: 100%;
  height: 100%;
}

.image-indicator {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  background: rgba(0, 0, 0, 0.5);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.image-indicator text {
  font-size: 24rpx;
  color: #fff;
}

.info-section {
  background: #fff;
  padding: 30rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #f5222d;
}

.price-value {
  font-size: 48rpx;
  color: #f5222d;
  font-weight: 600;
}

.original-price {
  margin-left: 20rpx;
}

.original-price text {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}

.sales {
  margin-left: auto;
}

.sales text {
  font-size: 24rpx;
  color: #999;
}

.title-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.product-title {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
}

.share-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
}

.share-icon {
  font-size: 36rpx;
}

.share-text {
  font-size: 22rpx;
  color: #999;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 22rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.spec-section {
  background: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.spec-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.spec-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #999;
}

.spec-value {
  font-size: 28rpx;
  color: #333;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
}

.qty-input {
  width: 80rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 10rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
}

.detail-section {
  background: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.detail-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-left {
  display: flex;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
}

.action-icon {
  font-size: 36rpx;
}

.action-text {
  font-size: 22rpx;
  color: #666;
}

.action-right {
  flex: 1;
  display: flex;
  margin-left: auto;
}

.cart-btn {
  flex: 1;
  height: 80rpx;
  background: #fff;
  color: #1890ff;
  font-size: 28rpx;
  border-radius: 40rpx 0 0 40rpx;
  border: 1rpx solid #1890ff;
  margin-right: -1rpx;
}

.buy-btn {
  flex: 1;
  height: 80rpx;
  background: #1890ff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 0 40rpx 40rpx 0;
  border: none;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 28rpx;
  color: #999;
}
