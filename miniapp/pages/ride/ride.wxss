.ride-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

.location-section {
  background: #fff;
  padding: 30rpx;
  position: relative;
}

.location-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.location-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.location-dot.from {
  background: #52c41a;
}

.location-dot.to {
  background: #f5222d;
}

.location-content {
  flex: 1;
}

.location-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.location-address {
  font-size: 30rpx;
  color: #333;
}

.location-swap {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 60rpx;
  height: 60rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1890ff;
}

.ride-types {
  background: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.type-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.type-list {
  display: flex;
  gap: 20rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.type-item.active {
  background: #e6f7ff;
  border-color: #1890ff;
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.type-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.type-price {
  font-size: 22rpx;
  color: #999;
}

.estimate-section {
  background: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.estimate-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.estimate-row.highlight {
  background: #fff7e6;
  margin: 0 -30rpx;
  padding: 16rpx 30rpx;
}

.estimate-label {
  font-size: 28rpx;
  color: #666;
}

.estimate-value {
  font-size: 28rpx;
  color: #333;
}

.estimate-row.highlight .estimate-value {
  font-size: 36rpx;
  color: #f5222d;
  font-weight: 600;
}

.tips-section {
  background: #fff;
  margin-top: 20rpx;
  padding: 60rpx 30rpx;
  text-align: center;
}

.tips-text {
  font-size: 28rpx;
  color: #999;
}

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.request-btn {
  width: 100%;
  height: 88rpx;
  background: #1890ff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.request-btn.disabled {
  background: #ccc;
}

.history-link {
  display: block;
  text-align: center;
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #1890ff;
}
