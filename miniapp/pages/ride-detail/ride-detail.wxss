.detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.status-section {
  padding: 60rpx 30rpx;
  text-align: center;
}

.status-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.countdown {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.driver-section {
  background: #fff;
  padding: 30rpx;
  margin-top: 20rpx;
}

.driver-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.driver-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.driver-detail {
  flex: 1;
}

.driver-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.driver-rating {
  display: flex;
  align-items: center;
}

.rating-star {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.rating-value {
  font-size: 26rpx;
  color: #fa8c16;
  margin-right: 20rpx;
}

.trip-count {
  font-size: 24rpx;
  color: #999;
}

.driver-actions {
  display: flex;
  gap: 20rpx;
}

.action-item {
  width: 80rpx;
  height: 80rpx;
  background: #e6f7ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  font-size: 36rpx;
}

.vehicle-info {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.vehicle-model {
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
}

.vehicle-plate {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: 600;
  margin-right: 20rpx;
}

.vehicle-color {
  font-size: 26rpx;
  color: #666;
}

.route-section {
  background: #fff;
  padding: 30rpx;
  margin-top: 20rpx;
}

.route-item {
  display: flex;
  align-items: flex-start;
}

.route-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 6rpx;
}

.route-dot.from {
  background: #52c41a;
}

.route-dot.to {
  background: #f5222d;
}

.route-content {
  flex: 1;
}

.route-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.route-address {
  font-size: 30rpx;
  color: #333;
}

.route-line {
  width: 2rpx;
  height: 40rpx;
  background: #e8e8e8;
  margin-left: 11rpx;
  margin: 10rpx 0 10rpx 11rpx;
}

.order-info {
  background: #fff;
  padding: 30rpx;
  margin-top: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.price-section {
  background: #fff;
  padding: 30rpx;
  margin-top: 20rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  font-size: 28rpx;
  color: #333;
}

.price-value.actual {
  font-size: 36rpx;
  color: #f5222d;
  font-weight: 600;
}

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.cancel-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #f5222d;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: 1rpx solid #f5222d;
}

.pay-btn, .rate-btn {
  width: 100%;
  height: 88rpx;
  background: #1890ff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}
