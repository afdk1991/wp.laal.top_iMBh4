<view class="help-container">
  <view class="search-section">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input 
        placeholder="搜索帮助内容" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
    </view>
  </view>
  
  <view class="quick-actions">
    <view class="action-item" bindtap="makePhoneCall">
      <text class="action-icon">📞</text>
      <text class="action-text">客服热线</text>
    </view>
    <view class="action-item" bindtap="goToFeedback">
      <text class="action-icon">💬</text>
      <text class="action-text">意见反馈</text>
    </view>
  </view>
  
  <view class="category-section">
    <view class="section-title">帮助分类</view>
    <view class="category-grid">
      <view 
        class="category-item" 
        wx:for="{{categories}}" 
        wx:key="id"
        bindtap="goToCategory"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>
  
  <view class="hot-section" wx:if="{{hotArticles.length > 0}}">
    <view class="section-title">热门问题</view>
    <view class="article-list">
      <view 
        class="article-item" 
        wx:for="{{hotArticles}}" 
        wx:key="id"
        bindtap="goToArticle"
        data-id="{{item.id}}"
      >
        <text class="article-title">{{item.title}}</text>
        <text class="article-arrow">›</text>
      </view>
    </view>
  </view>
  
  <view class="search-result" wx:if="{{articles.length > 0}}">
    <view class="section-title">搜索结果</view>
    <view class="article-list">
      <view 
        class="article-item" 
        wx:for="{{articles}}" 
        wx:key="id"
        bindtap="goToArticle"
        data-id="{{item.id}}"
      >
        <text class="article-title">{{item.title}}</text>
        <text class="article-arrow">›</text>
      </view>
    </view>
  </view>
  
  <view class="empty-tip" wx:if="{{!isLoading && categories.length === 0}}">
    <text>暂无帮助内容</text>
  </view>
</view>
