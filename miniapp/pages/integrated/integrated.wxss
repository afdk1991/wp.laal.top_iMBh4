/* 集成服务管理页面样式 */

.integrated-services-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.integrated-services-header {
  margin-bottom: 30rpx;
  padding: 20rpx 0;
}

.integrated-services-header .text-2xl {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a202c;
  margin-bottom: 8rpx;
}

.integrated-services-header .text-gray-600 {
  font-size: 24rpx;
  color: #718096;
}

.integrated-services-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
}

.stat-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.stat-icon .icon {
  font-size: 48rpx;
}

.stat-content {
  flex: 1;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a202c;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #718096;
}

.integrated-services-packages,
.integrated-services-subscriptions,
.integrated-services-orders {
  margin-bottom: 40rpx;
  background-color: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.section-header .text-xl {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a202c;
}

.add-btn {
  background-color: #3b82f6;
  color: white;
  border: none;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
}

.add-btn .btn-text {
  font-size: 24rpx;
}

.package-list,
.subscription-list,
.order-list {
  padding: 20rpx;
}

.table-header {
  display: flex;
  font-weight: 600;
  color: #4a5568;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
  font-size: 24rpx;
}

.table-header-cell {
  flex: 1;
  text-align: left;
  padding: 0 10rpx;
}

.table-row {
  display: flex;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
  font-size: 24rpx;
}

.table-cell {
  flex: 1;
  text-align: left;
  padding: 0 10rpx;
  word-break: break-word;
}

.status-badge {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 20rpx;
  font-weight: 500;
  display: inline-block;
}

.status-badge.active {
  background-color: #c6f6d5;
  color: #22543d;
}

.status-badge.inactive {
  background-color: #fed7d7;
  color: #742a2a;
}

.status-badge.expired {
  background-color: #feebc8;
  color: #7c3aed;
}

.status-badge.pending {
  background-color: #feebc8;
  color: #7c3aed;
}

.action-btn {
  background: none;
  border: none;
  padding: 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  display: inline-block;
}

.action-btn.edit {
  color: #3b82f6;
}

.action-btn.delete {
  color: #ef4444;
}

.action-btn.view {
  color: #10b981;
}

.action-btn .icon {
  font-size: 28rpx;
}

.search-box {
  display: flex;
  align-items: center;
}

.search-box input {
  padding: 16rpx 24rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx 0 0 12rpx;
  font-size: 24rpx;
  width: 300rpx;
}

.search-btn {
  background-color: #3b82f6;
  color: white;
  border: none;
  padding: 16rpx 32rpx;
  border-radius: 0 12rpx 12rpx 0;
}

.search-btn .icon {
  font-size: 24rpx;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: white;
  border-radius: 16rpx;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 4rpx 6rpx rgba(0, 0, 0, 0.1);
}

.modal-header {
  padding: 20rpx;
  border-bottom: 1rpx solid #e2e8f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a202c;
}

.modal-close {
  background: none;
  border: none;
  font-size: 36rpx;
  color: #718096;
  padding: 0;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
}

.modal-body {
  padding: 20rpx;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
  color: #4a5568;
  font-size: 24rpx;
}

.form-group input,
.form-group textarea {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.service-checkboxes {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
}

.checkbox-item checkbox {
  margin-right: 10rpx;
}

.picker {
  padding: 16rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #4a5568;
}

.modal-footer {
  padding: 20rpx;
  border-top: 1rpx solid #e2e8f0;
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-cancel {
  background-color: #f7fafc;
  color: #4a5568;
  border: 1rpx solid #e2e8f0;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.btn-submit {
  background-color: #3b82f6;
  color: white;
  border: none;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.order-detail-info {
  padding: 20rpx;
}

.info-row {
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.info-label {
  width: 200rpx;
  font-weight: 500;
  color: #4a5568;
  font-size: 24rpx;
}

.info-value {
  flex: 1;
  font-size: 24rpx;
}

.service-section {
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid #e2e8f0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: #1a202c;
}

.service-details {
  padding-left: 40rpx;
}

.detail-row {
  margin-bottom: 20rpx;
  display: flex;
  align-items: flex-start;
}

.detail-label {
  width: 200rpx;
  font-weight: 500;
  color: #4a5568;
  font-size: 24rpx;
}

.detail-value {
  flex: 1;
  font-size: 24rpx;
}

.items-list {
  flex: 1;
}

.item-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
  font-size: 24rpx;
}

.item-name {
  flex: 1;
}

.item-quantity {
  margin: 0 40rpx;
}

.item-price {
  font-weight: 500;
}
