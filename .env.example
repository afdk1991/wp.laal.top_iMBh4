# 服务器配置
PORT=8080
NODE_ENV=development
API_PREFIX=/api/v1

# 数据库配置
# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=mixmlaal

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB
MONGO_URI=mongodb://localhost:27017/mixmlaal

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# 安全配置
CORS_ORIGIN=*
CSRF_SECRET=your-csrf-secret-key-change-in-production
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=50m
LOG_MAX_FILES=5

# 第三方服务配置
# 支付服务
PAYMENT_API_KEY=your-payment-api-key
PAYMENT_API_SECRET=your-payment-api-secret

# 地图服务
MAP_API_KEY=your-map-api-key

# 短信服务
SMS_API_KEY=your-sms-api-key
SMS_SIGN=your-sms-sign

# 邮件服务
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
EMAIL_FROM=your-email@example.com

# 云存储
CLOUD_STORAGE_ACCESS_KEY=your-access-key
CLOUD_STORAGE_SECRET_KEY=your-secret-key
CLOUD_STORAGE_BUCKET=your-bucket-name

# 5G服务
FIVE_G_API_KEY=your-5g-api-key
FIVE_G_API_URL=https://api.5g-service.com

# 区块链服务
BLOCKCHAIN_API_KEY=your-blockchain-api-key
BLOCKCHAIN_NETWORK=testnet

# 监控配置
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# CI/CD配置
CI=true
CD=true
DEPLOY_ENV=development

# 其他配置
APP_NAME=MIXMLAAL
APP_VERSION=0.0.0.4
APP_DESCRIPTION=全球卓越的一站式多元化出行+本地生活生态平台

# 管理员配置
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# 测试配置
TEST_DB_HOST=localhost
TEST_DB_PORT=3306
TEST_DB_USER=root
TEST_DB_PASSWORD=password
TEST_DB_NAME=mixmlaal_test

# 生产环境配置（仅在生产环境使用）
# PROD_DB_HOST=production-db.example.com
# PROD_DB_PORT=3306
# PROD_DB_USER=prod_user
# PROD_DB_PASSWORD=prod_password
# PROD_DB_NAME=mixmlaal_prod

# 开发环境配置（仅在开发环境使用）
DEV_DB_HOST=localhost
DEV_DB_PORT=3306
DEV_DB_USER=root
DEV_DB_PASSWORD=password
DEV_DB_NAME=mixmlaal_dev