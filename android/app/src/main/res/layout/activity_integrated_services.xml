<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f5f5f5">

    <!-- 头部 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="集成服务管理"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="#1a202c" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="管理服务套餐和集成服务，融合出行服务和本地生活"
            android:textSize="16sp"
            android:textColor="#718096" />
    </LinearLayout>

    <!-- 统计卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:weightSum="2">
        <!-- 套餐数量 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#ffffff"
            android:padding="15dp"
            android:margin="5dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="2dp"
            android:backgroundTint="#ffffff"
            android:backgroundTintMode="src_in">
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="#e6f0ff"
                android:gravity="center"
                android:layout_marginRight="15dp"
                android:backgroundTint="#e6f0ff">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦"
                    android:textSize="32sp" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/stats_packages"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1a202c" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="服务套餐数量"
                    android:textSize="14sp"
                    android:textColor="#718096" />
            </LinearLayout>
        </LinearLayout>

        <!-- 订阅用户数 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#ffffff"
            android:padding="15dp"
            android:margin="5dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="2dp"
            android:backgroundTint="#ffffff"
            android:backgroundTintMode="src_in">
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="#e6ffe6"
                android:gravity="center"
                android:layout_marginRight="15dp"
                android:backgroundTint="#e6ffe6">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👥"
                    android:textSize="32sp" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/stats_subscribers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="128"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1a202c" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="订阅用户数"
                    android:textSize="14sp"
                    android:textColor="#718096" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:weightSum="2">
        <!-- 月收入 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#ffffff"
            android:padding="15dp"
            android:margin="5dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="2dp"
            android:backgroundTint="#ffffff"
            android:backgroundTintMode="src_in">
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="#f0e6ff"
                android:gravity="center"
                android:layout_marginRight="15dp"
                android:backgroundTint="#f0e6ff">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰"
                    android:textSize="32sp" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/stats_revenue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15800"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1a202c" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="月收入(元)"
                    android:textSize="14sp"
                    android:textColor="#718096" />
            </LinearLayout>
        </LinearLayout>

        <!-- 本月订单数 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#ffffff"
            android:padding="15dp"
            android:margin="5dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="2dp"
            android:backgroundTint="#ffffff"
            android:backgroundTintMode="src_in">
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="#fff0e6"
                android:gravity="center"
                android:layout_marginRight="15dp"
                android:backgroundTint="#fff0e6">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊"
                    android:textSize="32sp" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/stats_orders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="256"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1a202c" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本月订单数"
                    android:textSize="14sp"
                    android:textColor="#718096" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 服务套餐管理 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ffffff"
        android:margin="10dp"
        android:elevation="2dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="15dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务套餐管理"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1a202c"
                android:layout_weight="1" />
            <Button
                android:id="@+id/add_package_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ 添加套餐"
                android:backgroundTint="#3b82f6"
                android:textColor="#ffffff"
                android:padding="10dp 15dp" />
        </LinearLayout>
        <RecyclerView
            android:id="@+id/packages_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:minHeight="200dp" />
    </LinearLayout>

    <!-- 订阅管理 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ffffff"
        android:margin="10dp"
        android:elevation="2dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="15dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="订阅管理"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1a202c"
                android:layout_weight="1" />
            <Button
                android:id="@+id/add_subscription_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ 添加订阅"
                android:backgroundTint="#3b82f6"
                android:textColor="#ffffff"
                android:padding="10dp 15dp" />
        </LinearLayout>
        <RecyclerView
            android:id="@+id/subscriptions_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:minHeight="200dp" />
    </LinearLayout>

    <!-- 集成服务订单 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ffffff"
        android:margin="10dp"
        android:elevation="2dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="15dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="集成服务订单"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1a202c"
                android:layout_weight="1" />
        </LinearLayout>
        <RecyclerView
            android:id="@+id/orders_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp" />
    </LinearLayout>

</LinearLayout>
