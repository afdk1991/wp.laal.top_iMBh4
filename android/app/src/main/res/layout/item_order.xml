<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#f9fafb"
    android:padding="15dp"
    android:marginBottom="10dp"
    android:elevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="4">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="订单ID"
                android:textSize="14sp"
                android:textColor="#718096" />
            <TextView
                android:id="@+id/order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORDER001"
                android:textSize="16sp"
                android:textColor="#1a202c" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用户ID"
                android:textSize="14sp"
                android:textColor="#718096" />
            <TextView
                android:id="@+id/order_user_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1001"
                android:textSize="16sp"
                android:textColor="#1a202c" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用户姓名"
                android:textSize="14sp"
                android:textColor="#718096" />
            <TextView
                android:id="@+id/order_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="张三"
                android:textSize="16sp"
                android:textColor="#1a202c" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="套餐名称"
                android:textSize="14sp"
                android:textColor="#718096" />
            <TextView
                android:id="@+id/order_package_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="高级套餐"
                android:textSize="16sp"
                android:textColor="#1a202c" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:weightSum="3">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总金额"
                android:textSize="14sp"
                android:textColor="#718096" />
            <TextView
                android:id="@+id/order_total_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="105元"
                android:textSize="16sp"
                android:textColor="#1a202c" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="订单状态"
                android:textSize="14sp"
                android:textColor="#718096" />
            <TextView
                android:id="@+id/order_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="completed"
                android:textSize="14sp"
                android:padding="4dp 12dp"
                android:background="#c6f6d5"
                android:textColor="#22543d"
                android:backgroundTint="#c6f6d5" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="支付状态"
                android:textSize="14sp"
                android:textColor="#718096" />
            <TextView
                android:id="@+id/order_payment_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="paid"
                android:textSize="14sp"
                android:padding="4dp 12dp"
                android:background="#c6f6d5"
                android:textColor="#22543d"
                android:backgroundTint="#c6f6d5" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/order_created_at"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2024-01-01 10:00:00"
            android:textSize="14sp"
            android:textColor="#718096"
            android:layout_weight="1" />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/edit_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="编辑"
                android:backgroundTint="#3b82f6"
                android:textColor="#ffffff"
                android:padding="8dp 12dp"
                android:layout_marginRight="5dp" />
            <Button
                android:id="@+id/delete_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="删除"
                android:backgroundTint="#ef4444"
                android:textColor="#ffffff"
                android:padding="8dp 12dp"
                android:layout_marginRight="5dp" />
            <Button
                android:id="@+id/view_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="查看"
                android:backgroundTint="#10b981"
                android:textColor="#ffffff"
                android:padding="8dp 12dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
